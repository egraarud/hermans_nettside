# Kopier denne filen til .env og fyll inn verdiene

# Bootstrap admin-token (kun brukt for å opprette første admin-bruker)
ADMIN_TOKEN=bytt-meg-ut

# Hemmelig nøkkel for JWT-signering (bruk en lang, tilfeldig streng)
JWT_SECRET=bytt-meg-ut-med-lang-tilfeldig-streng

# JWT-gyldighet i minutter (standard: 7 dager)
JWT_EXPIRE_MINUTES=10080

# SMTP for utsending av midlertidige passord
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=din@epost.no
SMTP_PASS=ditt-app-passord
SMTP_FROM=Hermans Turnering <din@epost.no>
